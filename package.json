{
  "name": "distill",
  "private": true,
  "packageManager": "bun@1.3.4",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter @distill/web",
    "dev:mcp": "turbo run dev --filter @distill/mcp-server",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "knip": "knip --reporter compact"
  },
  "devDependencies": {
    "distill-mcp": "workspace:*",
    "expect-type": "^1.3.0",
    "knip": "^6.16.1",
    "prettier": "^3.8.4",
    "turbo": "^2.9.18",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
