+import { describe, it, expect } from "vitest";
+import { UserService } from "../services/users";
+
+describe("UserService", () => {
+  it("returns user name when user exists", () => {
+    const svc = new UserService();
+    expect(svc.getUserName({ name: "alice" })).toBe("alice");
+  });
+
+  it("throws on null user", () => {
+    const svc = new UserService();
+    expect(() => svc.getUserName(null)).toThrow("User is null");
+  });
+
+  it("counts users", async () => {
+    const svc = new UserService();
+    expect(await svc.countUsers()).toBeGreaterThanOrEqual(0);
+  });
+});
